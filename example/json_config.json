{
  "app": {
    "environment": "staging",
    "version": "2.1.0"
  },
  "server": {
    "port": 9090,
    "read_timeout": "60s",
    "tls": {
      "enabled": true
    }
  },
  "database": {
    "host": "db.staging.internal",
    "port": 5432,
    "name": "app_staging",
    "sslmode": "require"
  },
  "logging": {
    "level": "info",
    "output": "file",
    "file_path": "/var/log/app/staging.log"
  },
  "redis": {
    "host": "redis.staging.internal",
    "password": "redis_staging_pass"
  },
  "observability": {
    "tracing": {
      "enabled": true,
      "sampling_rate": 0.5,
      "exporter": "otlp",
      "endpoint": "http://otel-collector:4318"
    },
    "metrics": {
      "enabled": true,
      "path": "/metrics",
      "port": 9090
    }
  },
  "cors": {
    "allowed_origins": [
      "https://staging.example.com",
      "https://app.staging.example.com"
    ],
    "allowed_methods": [
      "GET",
      "POST",
      "PUT",
      "DELETE",
      "PATCH"
    ],
    "allowed_headers": [
      "Authorization",
      "Content-Type",
      "X-Request-ID"
    ],
    "max_age_seconds": 3600,
    "allow_credentials": true
  },
  "rate_limit": {
    "requests_per_second": 100,
    "burst": 200,
    "enabled": true
  },
  "cache": {
    "type": "redis",
    "default_ttl": "300s",
    "max_memory_mb": 512
  }
}
